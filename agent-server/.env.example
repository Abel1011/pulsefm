# --- Option A: Gemini Developer API (simple, API key only) ---
GOOGLE_API_KEY=your_gemini_api_key_here
# GOOGLE_GENAI_USE_VERTEXAI=false  (default)

# --- Option B: Vertex AI (requires gcloud auth application-default login) ---
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your_project_id
# GOOGLE_CLOUD_LOCATION=us-central1

# --- Music (Lyria, always uses Gemini Developer API) ---
# GEMINI_API_KEY=your_gemini_api_key_for_music

PORT=3001
